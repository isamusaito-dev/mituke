---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>送信完了｜Mituke</title>
    <meta name="robots" content="noindex" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="px-6 py-5 border-b border-[var(--line)]">
      <div class="max-w-5xl mx-auto">
        <Logo />
      </div>
    </header>

    <main class="flex-1 flex items-center justify-center px-6 py-16">
      <div class="text-center max-w-md">
        <p class="text-4xl mb-4">✉️</p>
        <h1 class="font-bold text-2xl text-[var(--green)] mb-3">
          ありがとうございます
        </h1>
        <p class="text-sm text-[var(--muted)] leading-relaxed mb-8">
          下のボタンから採用改善ガイド（PDF）をすぐにダウンロードできます。<br />
          より具体的に相談されたい方は、ヒアリング（無料・30分）もご利用ください。
        </p>
        <a
          href="/guide.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-3 rounded-full bg-[var(--green)] text-white text-sm font-bold hover:bg-[var(--green-deep)] transition-colors mb-3"
        >
          採用改善ガイドをダウンロード ↓
        </a>
        <p class="mb-4">
          <a
            href="https://timerex.net/s/mitsuke/900fc4c3"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[var(--navy)] font-medium underline underline-offset-2 hover:text-[var(--green)] transition-colors"
          >
            無料ヒアリングを予約する →
          </a>
        </p>
        <p class="text-xs text-[var(--muted)]">
          <a href="/" class="underline underline-offset-2">トップページに戻る</a>
        </p>
      </div>
    </main>

    <footer class="px-6 py-6 border-t border-[var(--line)]">
      <p class="text-center text-xs text-[var(--muted)]">
        © 2025 株式会社ハンチス (Hunches Co., Ltd.)
      </p>
    </footer>
  </body>
</html>
