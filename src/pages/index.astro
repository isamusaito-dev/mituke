---
import '../styles/global.css';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>無料採用力診断｜Mituke - 地方の採用を、見つけなおす</title>
    <meta
      name="description"
      content="10問・3分で、あなたの会社の採用力を5つの軸でスコア化。地方の中小企業に特化した無料診断ツールです。"
    />
    <!-- OGP -->
    <meta property="og:title" content="無料採用力診断｜Mituke" />
    <meta
      property="og:description"
      content="5つの軸で採用力を可視化。無料で今すぐ診断できます。"
    />
    <meta property="og:image" content="/og-default.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen">
    <!-- header -->
    <header class="px-6 py-5 border-b border-[var(--line)]">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="font-cormorant text-2xl font-medium text-[var(--green)] tracking-wide">
          Mituke
        </a>
        <span class="text-xs text-[var(--muted)] hidden sm:block">
          地方の採用を、見つけなおす。
        </span>
      </div>
    </header>

    <!-- hero -->
    <main>
      <section class="px-6 py-14 md:py-24 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-center">
          <!-- left: copy -->
          <div class="text-center md:text-left order-2 md:order-1">
            <p class="text-xs text-[var(--terracotta)] font-medium tracking-widest uppercase mb-5">
              Free Diagnosis Tool
            </p>
            <h1 class="font-bold text-3xl md:text-5xl text-[var(--ink)] leading-tight mb-6">
              あなたの会社の採用力を<br />
              <span class="text-[var(--green)]">5つの軸</span>で診断します。
            </h1>
            <p class="text-[var(--muted)] text-sm md:text-base leading-relaxed mb-8 max-w-xl mx-auto md:mx-0">
              10問・約3分。回答するだけで、認知力・訴求力・導線力・効率力・将来力のスコアが可視化されます。
              地方の中小企業に特化した、無料の採用力診断ツールです。
            </p>
            <a
              href="/diagnosis"
              class="inline-block px-8 py-4 rounded-full bg-[var(--green)] text-white text-sm font-medium hover:bg-[var(--green-deep)] transition-colors shadow-sm"
            >
              無料で採用力を診断する →
            </a>
            <p class="mt-4 text-xs text-[var(--muted)]">登録不要・完全無料</p>
          </div>

          <!-- right: hero image -->
          <div class="order-1 md:order-2">
            <img
              src="/hero.png"
              alt="地方の中小企業の採用力を5軸で診断するイメージ"
              width="1696"
              height="954"
              class="w-full h-auto rounded-2xl"
              loading="eager"
            />
          </div>
        </div>
      </section>

      <!-- features / 3ステップ -->
      <section class="px-6 py-16 border-t border-[var(--line)]">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <p class="text-xs text-[var(--terracotta)] font-medium tracking-widest uppercase mb-2">How it works</p>
            <h2 class="text-xl md:text-2xl font-bold text-[var(--ink)]">3ステップで、採用力がわかる</h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {[
              {
                step: 'STEP 1',
                action: '答える',
                stat: '10',
                unit: '問',
                title: '質問に答えるだけ',
                desc: '採用の現状を把握する厳選された設問。1問ずつ、選ぶだけで進みます。',
                pills: ['かんたん4択', '1問ずつ表示', '約3分'],
                icon: 'check',
              },
              {
                step: 'STEP 2',
                action: '診断する',
                stat: '5',
                unit: '軸',
                title: '5つの軸でスコア化',
                desc: '回答をもとに、採用力を5つの観点で自動採点。弱点が一目でわかります。',
                pills: ['認知', '訴求', '導線', '効率', '将来'],
                icon: 'radar',
              },
              {
                step: 'STEP 3',
                action: '受け取る',
                stat: '¥0',
                unit: '',
                title: '完全無料で受け取れる',
                desc: '診断結果に加え、改善策をまとめた詳細レポートまで費用は一切かかりません。',
                pills: ['診断結果', '詳細レポート', '個別相談'],
                icon: 'gift',
              },
            ].map(({ step, action, stat, unit, title, desc, pills, icon }) => (
              <div class="bg-[var(--paper)] border border-[var(--line)] rounded-2xl p-7 flex flex-col gap-4">
                <!-- step eyebrow -->
                <div class="flex items-center gap-2">
                  <span class="w-7 h-7 rounded-full bg-[var(--green)] text-white text-xs font-bold flex items-center justify-center shrink-0">
                    {step.replace('STEP ', '')}
                  </span>
                  <span class="text-xs text-[var(--muted)] font-medium tracking-wide">{step} ／ {action}</span>
                </div>

                <!-- icon + stat -->
                <div class="flex items-end justify-between">
                  <p class="text-5xl font-bold text-[var(--terracotta)] leading-none">
                    {stat}<span class="text-2xl ml-0.5">{unit}</span>
                  </p>
                  <div class="w-11 h-11 rounded-xl bg-[var(--green)]/8 flex items-center justify-center">
                    {icon === 'check' && (
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="3" width="16" height="18" rx="2" stroke="#3B5A3F" stroke-width="1.5"/>
                        <path d="M8 11l2.5 2.5L16 8" stroke="#3B5A3F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                    {icon === 'radar' && (
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="12,3 20.5,9 17.5,19 6.5,19 3.5,9" stroke="#3B5A3F" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                        <polygon points="12,7.5 17,11 15,17 9,17 7,11" stroke="#3B5A3F" stroke-width="1" fill="#3B5A3F" fill-opacity="0.15" stroke-linejoin="round"/>
                      </svg>
                    )}
                    {icon === 'gift' && (
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3.5" y="9" width="17" height="12" rx="1.5" stroke="#3B5A3F" stroke-width="1.5"/>
                        <path d="M3 9h18M12 9v12" stroke="#3B5A3F" stroke-width="1.5"/>
                        <path d="M12 9S10.5 4 8 5s.5 4 4 4zM12 9s1.5-5 4-4-.5 4-4 4z" stroke="#3B5A3F" stroke-width="1.5" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </div>
                </div>

                <!-- title + desc -->
                <div>
                  <p class="text-base font-bold text-[var(--ink)] mb-1.5">{title}</p>
                  <p class="text-sm text-[var(--muted)] leading-relaxed">{desc}</p>
                </div>

                <!-- unified pill row -->
                <div class="mt-auto pt-1 flex flex-wrap gap-1.5">
                  {pills.map((p) => (
                    <span class="text-[11px] px-2.5 py-1 rounded-full bg-[var(--green)]/8 text-[var(--green)] font-medium">{p}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>

    <!-- footer -->
    <footer class="px-6 py-8 border-t border-[var(--line)] bg-[var(--green-deep)] mt-20">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
        <span class="font-cormorant text-xl text-white/80">Mituke</span>
        <p class="text-xs text-white/50">
          © 2025 株式会社ハンチス (Hunches Co., Ltd.) · 対応エリア：長野・群馬・山梨・新潟・埼玉・栃木
        </p>
      </div>
    </footer>
  </body>
</html>
