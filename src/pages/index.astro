---
import '../styles/global.css';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>無料採用力診断｜Mituke - 地方の採用を、見つけなおす</title>
    <meta
      name="description"
      content="10問・3分で、あなたの会社の採用力を5つの軸でスコア化。地方の中小企業に特化した無料診断ツールです。"
    />
    <!-- OGP -->
    <meta property="og:title" content="無料採用力診断｜Mituke" />
    <meta
      property="og:description"
      content="5つの軸で採用力を可視化。無料で今すぐ診断できます。"
    />
    <meta property="og:image" content="/og-default.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen">
    <!-- header -->
    <header class="px-6 py-5 border-b border-[var(--line)]">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="font-cormorant text-2xl font-medium text-[var(--green)] tracking-wide">
          Mituke
        </a>
        <span class="text-xs text-[var(--muted)] hidden sm:block">
          地方の採用を、見つけなおす。
        </span>
      </div>
    </header>

    <!-- hero -->
    <main>
      <section class="px-6 py-20 md:py-32 text-center max-w-3xl mx-auto">
        <p class="text-xs text-[var(--terracotta)] font-medium tracking-widest uppercase mb-6">
          Free Diagnosis Tool
        </p>
        <h1 class="font-serif font-semibold text-3xl md:text-5xl text-[var(--ink)] leading-tight mb-6">
          あなたの会社の採用力を<br />
          <span class="text-[var(--green)]">5つの軸</span>で診断します。
        </h1>
        <p class="text-[var(--muted)] text-sm md:text-base leading-relaxed mb-10 max-w-xl mx-auto">
          10問・約3分。回答するだけで、認知力・訴求力・導線力・効率力・将来力のスコアが可視化されます。
          地方の中小企業に特化した、無料の採用力診断ツールです。
        </p>
        <a
          href="/diagnosis"
          class="inline-block px-8 py-4 rounded-full bg-[var(--green)] text-white text-sm font-medium hover:bg-[var(--green-deep)] transition-colors shadow-sm"
        >
          無料で採用力を診断する →
        </a>
        <p class="mt-4 text-xs text-[var(--muted)]">登録不要・完全無料</p>
      </section>

      <!-- features -->
      <section class="px-6 py-16 border-t border-[var(--line)]">
        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-5">

          <!-- 10問 -->
          <div class="bg-[var(--paper)] border border-[var(--line)] rounded-2xl p-7 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--green)]/10 flex items-center justify-center">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="3" width="16" height="18" rx="2" stroke="#3B5A3F" stroke-width="1.5"/>
                <line x1="8" y1="8" x2="16" y2="8" stroke="#3B5A3F" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="8" y1="12" x2="16" y2="12" stroke="#3B5A3F" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="8" y1="16" x2="13" y2="16" stroke="#3B5A3F" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <p class="text-4xl font-bold text-[var(--terracotta)] mb-1 leading-none">10問</p>
              <p class="text-xs text-[var(--muted)] font-medium tracking-wide uppercase mb-3">Questions</p>
              <p class="text-sm text-[var(--ink)] leading-relaxed">採用の現状を把握する<br/>厳選された設問</p>
            </div>
            <div class="mt-auto flex flex-wrap gap-2">
              {['認知', '訴求', '導線', '効率', '将来'].map((tag) => (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--green)]/8 text-[var(--green)] font-medium">{tag}</span>
              ))}
            </div>
          </div>

          <!-- 5軸 -->
          <div class="bg-[var(--green)] rounded-2xl p-7 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polygon points="12,3 20.5,9 17.5,19 6.5,19 3.5,9" stroke="white" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                <polygon points="12,7.5 17,11 15,17 9,17 7,11" stroke="white" stroke-width="1" fill="white" fill-opacity="0.2" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-4xl font-bold text-white mb-1 leading-none">5軸</p>
              <p class="text-xs text-white/60 font-medium tracking-wide uppercase mb-3">Dimensions</p>
              <p class="text-sm text-white/85 leading-relaxed">認知・訴求・導線・効率・将来の<br/>視点でスコア化</p>
            </div>
            <div class="mt-auto">
              <div class="grid grid-cols-5 gap-1">
                {[75, 50, 88, 62, 40].map((h) => (
                  <div class="flex flex-col items-center gap-1">
                    <div class="w-full bg-white/20 rounded-full overflow-hidden" style="height:40px; display:flex; align-items:flex-end;">
                      <div class="w-full rounded-full bg-white/70" style={`height:${h}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- 無料 -->
          <div class="bg-[var(--paper)] border border-[var(--line)] rounded-2xl p-7 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--terracotta)]/10 flex items-center justify-center">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="#B84130" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-4xl font-bold text-[var(--terracotta)] mb-1 leading-none">無料</p>
              <p class="text-xs text-[var(--muted)] font-medium tracking-wide uppercase mb-3">Completely Free</p>
              <p class="text-sm text-[var(--ink)] leading-relaxed">診断から詳細レポート<br/>受け取りまで完全無料</p>
            </div>
            <div class="mt-auto space-y-2">
              {['診断ツール', '詳細レポート（20〜25p）', 'ヒアリング相談'].map((item) => (
                <div class="flex items-center gap-2 text-xs text-[var(--muted)]">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" fill="#B84130" fill-opacity="0.12"/><path d="M4.5 7L6.5 9L9.5 5.5" stroke="#B84130" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {item}
                </div>
              ))}
            </div>
          </div>

        </div>
      </section>
    </main>

    <!-- footer -->
    <footer class="px-6 py-8 border-t border-[var(--line)] bg-[var(--green-deep)] mt-20">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
        <span class="font-cormorant text-xl text-white/80">Mituke</span>
        <p class="text-xs text-white/50">
          © 2025 株式会社ハンチス (Hunches Co., Ltd.) · 対応エリア：長野・群馬・山梨・新潟・埼玉・栃木
        </p>
      </div>
    </footer>
  </body>
</html>
