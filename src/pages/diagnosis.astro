---
import '../styles/global.css';
import DiagnosisTool from '../components/DiagnosisTool';
import Logo from '../components/Logo.astro';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>採用力診断｜Mitsuke</title>
    <meta
      name="description"
      content="10問・3分で、あなたの会社の採用力を5つの軸でスコア化します。"
    />
    <meta name="robots" content="noindex" />
  </head>
  <body class="min-h-screen">
    <!-- header -->
    <header class="px-6 py-5 border-b border-[var(--line)]">
      <div class="max-w-5xl mx-auto">
        <Logo />
      </div>
    </header>

    <main class="px-6 py-12 md:py-16">
      <div class="max-w-[600px] mx-auto">
        <div class="mb-8">
          <h1 class="font-serif font-semibold text-xl text-[var(--ink)] mb-1">
            採用力診断
          </h1>
          <p class="text-xs text-[var(--muted)]">10問・約3分で完了します</p>
        </div>
        <div class="bg-[var(--paper)] rounded-2xl p-6 md:p-8 shadow-sm border border-[var(--line)]">
          <DiagnosisTool client:load />
        </div>
      </div>
    </main>

    <footer class="px-6 py-6 border-t border-[var(--line)] mt-16">
      <p class="text-center text-xs text-[var(--muted)]">
        © 2025 株式会社ハンチス · <a href="/" class="underline underline-offset-2">トップに戻る</a>
      </p>
    </footer>
  </body>
</html>
