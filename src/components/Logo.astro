---
interface Props {
  variant?: 'default' | 'light';
  class?: string;
}
const { variant = 'default', class: className = '' } = Astro.props;
const src = variant === 'light' ? '/logo-white.svg' : '/logo.svg';
---

<a href="/" class={`inline-block ${className}`} aria-label="mitsuke ホーム">
  <img src={src} alt="mitsuke" style="height:30px;width:auto;display:block;" />
</a>
